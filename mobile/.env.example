# Base URL of the NestJS backend the app talks to.
#
# - iOS Simulator can use localhost (this is also the in-code default).
# - On a REAL iPhone, set this to your Mac's LAN IP so the phone can reach the
#   server over Wi-Fi. Find the IP with: ipconfig getifaddr en0
#
# EXPO_PUBLIC_* vars are inlined at bundle time — restart Expo after changing
# this value (npx expo start -c).
EXPO_PUBLIC_API_BASE=http://localhost:3000
