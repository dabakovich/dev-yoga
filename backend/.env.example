# HTTP port the NestJS server listens on
PORT=3000

# Network interface to bind to. "0.0.0.0" listens on all interfaces, so the
# server is reachable on the machine's LAN IP (e.g. http://192.168.0.101:3000)
# — needed to access it from a phone on the same Wi-Fi. Use "127.0.0.1" to
# restrict to localhost only.
HOST=0.0.0.0

# Path to the SQLite database file (relative to the backend working dir)
DATABASE_PATH=data/dev.sqlite

# When "true", TypeORM auto-creates/updates tables from entities on boot.
# Convenient in development; turn OFF in production (use migrations instead).
DB_SYNCHRONIZE=true
